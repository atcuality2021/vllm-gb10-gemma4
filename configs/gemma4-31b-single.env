# =============================================================================
# Gemma 4 31B — Single DGX Spark GB10 Node
# =============================================================================
# Dense 31B model. All parameters active per token.
# Expect ~3.8 tok/s on GB10. Good for batch/offline, not interactive.
#
# Usage:
#   set -a && source gemma4-31b-single.env && set +a
#   vllm serve $MODEL_PATH $VLLM_ARGS
# =============================================================================

# Model
MODEL_PATH=$HOME/hf_models/gemma-4-31B-it
SERVED_MODEL_NAME=gemma-4-31b

# vLLM settings
VLLM_PORT=8000
GPU_MEMORY_UTILIZATION=0.55
MAX_MODEL_LEN=8192
MAX_NUM_SEQS=4
TENSOR_PARALLEL_SIZE=1

# GB10 required
ENFORCE_EAGER=1
TRUST_REMOTE_CODE=1
ENABLE_PREFIX_CACHING=1

# Ray (unified memory)
RAY_memory_usage_threshold=1.0

# HuggingFace
HF_HUB_OFFLINE=1

# NCCL (single node)
NCCL_P2P_DISABLE=1
NCCL_IB_DISABLE=1

# Construct vLLM args
VLLM_ARGS="--port $VLLM_PORT \
  --gpu-memory-utilization $GPU_MEMORY_UTILIZATION \
  --max-model-len $MAX_MODEL_LEN \
  --max-num-seqs $MAX_NUM_SEQS \
  --trust-remote-code \
  --enforce-eager \
  --enable-prefix-caching"
