# =============================================================================
# Qwen3.5-122B-A10B-FP8 — Multi-Node (2x DGX Spark GB10)
# =============================================================================
# MoE model: 122B total, 10B active per token. FP8 quantized.
# Requires 2 GB10 nodes connected via 200 GbE QSFP.
# Tensor parallel size 2, Ray distributed executor.
#
# Usage:
#   1. Start Ray head on node 1 (see launch instructions below)
#   2. Start Ray worker on node 2
#   3. Launch vLLM on node 1
# =============================================================================

# Model
MODEL_PATH=$HOME/hf_models/Qwen3.5-122B-A10B-FP8
SERVED_MODEL_NAME=manthan-general

# vLLM settings
VLLM_PORT=8000
GPU_MEMORY_UTILIZATION=0.80
MAX_MODEL_LEN=16384
MAX_NUM_SEQS=8
TENSOR_PARALLEL_SIZE=2
DISTRIBUTED_EXECUTOR_BACKEND=ray

# Reasoning / tool calling
REASONING_PARSER=qwen3
TOOL_CALL_PARSER=qwen3_coder

# GB10 required
ENFORCE_EAGER=1
TRUST_REMOTE_CODE=1
ENABLE_PREFIX_CACHING=1

# Ray (unified memory — set on ALL nodes)
RAY_memory_usage_threshold=1.0

# HuggingFace
HF_HUB_OFFLINE=1

# NCCL (multi-node — set on ALL nodes)
NCCL_SOCKET_IFNAME=enp1s0f0np0
NCCL_P2P_DISABLE=1
NCCL_IB_DISABLE=1
NCCL_NET_GDR_LEVEL=SYS
# NCCL_DEBUG=INFO  # Uncomment for debugging

# Custom NCCL library path (must be built on both nodes)
# export LD_LIBRARY_PATH=$HOME/nccl/build/lib:$LD_LIBRARY_PATH

# Node IPs (QSFP network — adjust to your setup)
# NODE1_QSFP_IP=192.168.100.10
# NODE2_QSFP_IP=192.168.100.11

# === Launch Instructions ===
#
# Node 1 (head):
#   export VLLM_HOST_IP=192.168.100.10
#   export RAY_memory_usage_threshold=1.0
#   export LD_LIBRARY_PATH=$HOME/nccl/build/lib:$LD_LIBRARY_PATH
#   source ~/vllm-env/bin/activate
#   ray start --head --port=6379
#
# Node 2 (worker):
#   export VLLM_HOST_IP=192.168.100.11
#   export RAY_memory_usage_threshold=1.0
#   export LD_LIBRARY_PATH=$HOME/nccl/build/lib:$LD_LIBRARY_PATH
#   source ~/vllm-env/bin/activate
#   ray start --address=192.168.100.10:6379
#
# Node 1 (vLLM):
#   vllm serve $MODEL_PATH \
#     --tensor-parallel-size 2 \
#     --distributed-executor-backend ray \
#     --gpu-memory-utilization 0.80 \
#     --max-model-len 16384 \
#     --trust-remote-code --enforce-eager \
#     --enable-prefix-caching \
#     --reasoning-parser qwen3 \
#     --tool-call-parser qwen3_coder \
#     --max-num-batched-tokens 4096
