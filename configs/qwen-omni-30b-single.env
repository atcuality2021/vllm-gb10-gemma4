# =============================================================================
# Qwen3-Omni-30B-A3B — Single DGX Spark GB10 Node
# =============================================================================
# MoE model: 30B total, 3B active per token.
# Expect ~28 tok/s on GB10. Best single-node model for interactive use.
#
# Usage:
#   set -a && source qwen-omni-30b-single.env && set +a
#   vllm serve $MODEL_PATH $VLLM_ARGS
# =============================================================================

# Model
MODEL_PATH=$HOME/hf_models/Qwen3-Omni-30B-A3B-Instruct
SERVED_MODEL_NAME=qwen-omni-30b

# vLLM settings
VLLM_PORT=8000
GPU_MEMORY_UTILIZATION=0.85
MAX_MODEL_LEN=16384
MAX_NUM_SEQS=16
TENSOR_PARALLEL_SIZE=1

# GB10 required
ENFORCE_EAGER=1
TRUST_REMOTE_CODE=1
ENABLE_PREFIX_CACHING=1

# Ray (unified memory)
RAY_memory_usage_threshold=1.0

# HuggingFace
HF_HUB_OFFLINE=1

# NCCL (single node)
NCCL_P2P_DISABLE=1
NCCL_IB_DISABLE=1

# Construct vLLM args
VLLM_ARGS="--port $VLLM_PORT \
  --gpu-memory-utilization $GPU_MEMORY_UTILIZATION \
  --max-model-len $MAX_MODEL_LEN \
  --max-num-seqs $MAX_NUM_SEQS \
  --trust-remote-code \
  --enforce-eager \
  --enable-prefix-caching \
  --max-num-batched-tokens 4096"
